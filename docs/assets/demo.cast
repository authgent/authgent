[3.532, "o", "\u001b[3m                                       \u001b[0m\u001b[1;3mAfter Revocation\u001b[0m\u001b[3m                                        \u001b[0m\r\n\u001b[2m╭────────────────────┬────────────────┬────────────────┬──────────────────────────────────────╮\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mToken Owner       \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m    Before    \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m    After     \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mWhy                                 \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m\r\n\u001b[2m├────────────────────┼────────────────┼────────────────┼──────────────────────────────────────┤\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;36m🎯 Orchestrator\u001b[0m\u001b[1m   \u001b[0m\u001b[1m \u001b[0m"]
[0.000, "o", "\u001b[2m│\u001b[0m    \u001b[32m✓ active\u001b[0m    \u001b[2m│\u001b[0m   \u001b[1;31m✗ REVOKED\u001b[0m    \u001b[2m│\u001b[0m \u001b[2mWe just revoked it\u001b[0m                   \u001b[2m│\u001b[0m\r\n\u001b[2m├────────────────────┼────────────────┼────────────────┼──────────────────────────────────────┤\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;35m🔍 Search Agent\u001b[0m\u001b[1m   \u001b[0m\u001b[1m \u001b[0m\u001b[2m│\u001b[0m    \u001b[32m✓ active\u001b[0m    \u001b[2m│\u001b[0m    \u001b[1;32m✓ active\u001b[0m    \u001b[2m│\u001b[0m \u001b[2mIndependent token — still valid\u001b[0m      \u001b[2m│\u001b[0m\r\n\u001b[2m├────────────────────┼────────────────┼────────────────┼──────────────────────────────────────┤\u001b[0m\r\n\u001b[2m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;33m🗄️  DB Agent\u001b[0m\u001b[1m       \u001b[0m\u001b[1m "]
[0.000, "o", "\u001b[0m\u001b[2m│\u001b[0m    \u001b[32m✓ active\u001b[0m    \u001b[2m│\u001b[0m    \u001b[1;32m✓ active\u001b[0m    \u001b[2m│\u001b[0m \u001b[2mIndependent token — still valid\u001b[0m      \u001b[2m│\u001b[0m\r\n\u001b[2m╰────────────────────┴────────────────┴────────────────┴──────────────────────────────────────╯\u001b[0m\r\n"]
