[0.512, "o", "\u001b[96m╭──────┬────────────────────────────────────────────────────┬────────────────╮\u001b[0m\r\n\u001b[96m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m    \u001b[0m\u001b[1m \u001b[0m\u001b[96m│\u001b[0m\u001b[1m \u001b[0m\u001b[1mWhat happened                                     \u001b[0m\u001b[1m \u001b[0m\u001b[96m│\u001b[0m\u001b[1m \u001b[0m\u001b[1m              \u001b[0m\u001b[1m \u001b[0m\u001b[96m│\u001b[0m\r\n\u001b[96m├──────┼────────────────────────────────────────────────────┼────────────────┤\u001b[0m\r\n\u001b[96m│\u001b[0m  1   \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mThree agents registered with different scopes     \u001b[0m\u001b[97m \u001b[0m\u001b[96m│\u001b[0m       \u001b[32m✓\u001b[0m        \u001b[96m│\u001b[0m\r\n\u001b[96m├──────┼─────────────────────────────────────────────────"]
[0.000, "o", "───┼────────────────┤\u001b[0m\r\n\u001b[96m│\u001b[0m  2   \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mOrchestrator got a token                          \u001b[0m\u001b[97m \u001b[0m\u001b[96m│\u001b[0m       \u001b[32m✓\u001b[0m        \u001b[96m│\u001b[0m\r\n\u001b[96m├──────┼────────────────────────────────────────────────────┼────────────────┤\u001b[0m\r\n\u001b[96m│\u001b[0m  3   \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mOrchestrator delegated to Search Agent (scope     \u001b[0m\u001b[97m \u001b[0m\u001b[96m│\u001b[0m       \u001b[32m✓\u001b[0m        \u001b[96m│\u001b[0m\r\n\u001b[96m│\u001b[0m      \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mnarrowed)                                         \u001b[0m\u001b[97m \u001b[0m\u001b[96m│\u001b[0m                \u001b[96m│\u001b[0m\r\n\u001b[96m├──────┼────────────────────────────────────────────────────┼───────────────"]
[0.000, "o", "─┤\u001b[0m\r\n\u001b[96m│\u001b[0m  4   \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mOrchestrator delegated to DB Agent (scope         \u001b[0m\u001b[97m \u001b[0m\u001b[96m│\u001b[0m       \u001b[32m✓\u001b[0m        \u001b[96m│\u001b[0m\r\n\u001b[96m│\u001b[0m      \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mnarrowed)                                         \u001b[0m\u001b[97m \u001b[0m\u001b[96m│\u001b[0m                \u001b[96m│\u001b[0m\r\n\u001b[96m├──────┼────────────────────────────────────────────────────┼────────────────┤\u001b[0m\r\n\u001b[96m│\u001b[0m  5   \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mSearch Agent tried to escalate scope              \u001b[0m\u001b[97m \u001b[0m\u001b[96m│\u001b[0m    \u001b[1;31mBLOCKED\u001b[0m     \u001b[96m│\u001b[0m\r\n\u001b[96m├──────┼────────────────────────────────────────────────────┼────────────────┤\u001b[0m\r\n\u001b[96m│\u001b[0m  6   \u001b[96m│\u001b[0m\u001b[97m \u001b[0m\u001b[97mAll "]
